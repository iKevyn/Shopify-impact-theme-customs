<search-drawer {% if request.design_mode %}handle-section-events{% endif %} class="search-drawer {% if section.settings.full_width %}search-drawer--full{% endif %} drawer drawer--lg" id="search-drawer">
  <form action="{{ routes.search_url }}" method="get" class="v-stack gap-5 sm:gap-8" role="search">
    <div class="search-input">
      <input 
        type="search" 
        name="q" 
        id="search-input"
        placeholder="{{ 'search.general.search_placeholder' | t }}" 
        autocomplete="off" 
        autocorrect="off" 
        autocapitalize="off" 
        spellcheck="false" 
        aria-label="{{ 'search.general.title' | t | escape }}">
      <button type="reset" class="text-subdued">{{ 'search.general.clear' | t }}</button>
      <button type="button" is="close-button">
        <span class="sr-only">{{ 'general.accessibility.close' | t }}</span>
        {%- render 'icon' with 'close' -%}
      </button>
    </div>

    <style>
      #shopify-section-{{ section.id }} {
        --predictive-search-column-count: 3;
      }

      .custom-search-results {
        display: grid;
        gap: 1.5rem;
      }

      .search-item {
        display: grid;
        grid-template-columns: 80px 1fr;
        gap: 1rem;
        align-items: start;
        text-decoration: none;
        color: inherit;
      }

      .search-item-image {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 4px;
        background: var(--color-background-secondary);
      }

      .search-item-content {
        display: grid;
        gap: 0.5rem;
      }

      .search-item-title {
        font-weight: 500;
        text-decoration: none;
        color: var(--color-text);
      }

      .search-item-title:hover {
        text-decoration: underline;
      }

      .search-item-price {
        font-size: 0.875rem;
        color: var(--color-text-secondary);
      }

      .search-loading {
        display: none;
        gap: 1rem;
      }

      .search-loading.active {
        display: grid;
      }

      .search-empty {
        display: none;
        text-align: center;
        padding: 2rem 1rem;
      }

      .search-empty.active {
        display: block;
      }

      .search-idle {
        display: grid;
        gap: 1rem;
      }

      .search-idle.hidden {
        display: none;
      }

      .search-results-wrapper {
        display: none;
      }

      .search-results-wrapper.active {
        display: block;
      }

      @media (max-width: 768px) {
        .search-results-wrapper {
          max-height: 60vh;
          overflow-y: auto;
          -webkit-overflow-scrolling: touch;
          padding-right: 0.5rem;
        }

        .search-results-wrapper::-webkit-scrollbar {
          width: 6px;
        }

        .search-results-wrapper::-webkit-scrollbar-track {
          background: transparent;
        }

        .search-results-wrapper::-webkit-scrollbar-thumb {
          background: var(--color-border);
          border-radius: 3px;
        }

        .search-results-wrapper::-webkit-scrollbar-thumb:hover {
          background: var(--color-text-secondary);
        }
      }
    </style>

    <input type="hidden" name="type" value="product">

    <div class="custom-search-results" id="search-results">
      <!-- Idle state -->
      <div class="search-idle" id="search-idle">
        {%- if section.settings.search_menu.links.size > 0 -%}
          <div class="v-stack gap-3 sm:gap-4">
            {%- if section.settings.search_menu_show_title -%}
              <p class="bold text-subdued">{{ section.settings.search_menu.title }}</p>
            {%- endif -%}

            <ul class="v-stack gap-2 sm:gap-3" role="list">
              {%- for link in section.settings.search_menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="h5">
                    <span class="reversed-link hover:show">{{ link.title }}</span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      <!-- Loading state -->
      <div class="search-loading" id="search-loading">
        <p>Carregando...</p>
      </div>

      <!-- Empty state -->
      <div class="search-empty" id="search-empty">
        <p class="h6">{{ 'search.general.no_results' | t }}</p>
      </div>

      <!-- Results container -->
      <div class="search-results-wrapper" id="search-results-container"></div>
    </div>
  </form>
</search-drawer>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-input');
    const searchIdle = document.getElementById('search-idle');
    const searchLoading = document.getElementById('search-loading');
    const searchEmpty = document.getElementById('search-empty');
    const searchResultsContainer = document.getElementById('search-results-container');
    let searchTimeout;

    searchInput.addEventListener('input', function() {
      const query = this.value.trim();

      clearTimeout(searchTimeout);

      if (query.length < 2) {
        searchIdle.classList.remove('hidden');
        searchLoading.classList.remove('active');
        searchEmpty.classList.remove('active');
        searchResultsContainer.classList.remove('active');
        return;
      }

      searchIdle.classList.add('hidden');
      searchLoading.classList.add('active');
      searchEmpty.classList.remove('active');
      searchResultsContainer.classList.remove('active');

      searchTimeout = setTimeout(() => {
        performSearch(query);
      }, 300);
    });

    let allSearchResults = [];

    async function performSearch(query) {
      try {
        const response = await fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=50`);
        const data = await response.json();

        if (!data.resources.results.products || data.resources.results.products.length === 0) {
          searchLoading.classList.remove('active');
          searchEmpty.classList.add('active');
          searchResultsContainer.classList.remove('active');
          return;
        }

        allSearchResults = data.resources.results.products;
        renderSearchResults(allSearchResults.slice(0, 15));
        searchLoading.classList.remove('active');
        searchEmpty.classList.remove('active');
        searchResultsContainer.classList.add('active');
      } catch (error) {
        console.error('Erro ao buscar:', error);
        searchLoading.classList.remove('active');
        searchEmpty.classList.add('active');
      }
    }

    function renderSearchResults(products) {
      if (!products || products.length === 0) {
        searchEmpty.classList.add('active');
        searchResultsContainer.innerHTML = '';
        return;
      }

      let html = '<div class="v-stack gap-4 sm:gap-6" id="products-list">';

      products.forEach(product => {
        const image = product.image || '';
        const price = product.price ? `R$ ${(product.price).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.')}` : '';
        
        html += `
          <a href="${product.url}" class="search-item">
            ${image ? `<img src="${image}" alt="${product.title}" class="search-item-image">` : '<div class="search-item-image"></div>'}
            <div class="search-item-content">
              <span class="search-item-title">${product.title}</span>
              ${price ? `<span class="search-item-price">${price}</span>` : ''}
            </div>
          </a>
        `;
      });

      html += '</div>';

      // Adicionar botão "Carregar mais" se houver mais itens
      if (allSearchResults.length > products.length) {
        html += `
          <div style="display: flex; justify-content: center; margin-top: 1.5rem;">
            <button type="button" id="load-more-btn" class="button" style="padding: 0.75rem 1.5rem; border: 1px solid var(--color-border); background: transparent; cursor: pointer; border-radius: 4px;">
              Carregar mais (${allSearchResults.length - products.length} restantes)
            </button>
          </div>
        `;
      }

      searchResultsContainer.innerHTML = html;

      // Adicionar listener ao botão "Carregar mais"
      const loadMoreBtn = document.getElementById('load-more-btn');
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function() {
          const currentCount = document.querySelectorAll('.search-item').length;
          const newCount = currentCount + 15;
          renderSearchResults(allSearchResults.slice(0, newCount));
        });
      }
    }

    const resetButton = document.querySelector('button[type="reset"]');
    if (resetButton) {
      resetButton.addEventListener('click', function() {
        searchInput.value = '';
        searchIdle.classList.remove('hidden');
        searchLoading.classList.remove('active');
        searchEmpty.classList.remove('active');
        searchResultsContainer.classList.remove('active');
        searchResultsContainer.innerHTML = '';
      });
    }
  });
</script>

{% schema %}
{
  "name": "Search drawer",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_article_category",
      "label": "Show blog post category",
      "info": "Add tag organize blog posts [Learn more](https://help.shopify.com/en/manual/online-store/blogs/writing-blogs#add-tags-to-a-blog-post).",
      "default": true
    },
    {
      "type": "header",
      "content": "Featured links",
      "info": "Promote collections, products or important pages when search terms is empty."
    },
    {
      "type": "link_list",
      "id": "search_menu",
      "label": "Menu",
      "info": "This menu won't show dropdown items."
    },
    {
      "type": "checkbox",
      "id": "search_menu_show_title",
      "label": "Show menu title",
      "default": true
    }
  ]
}
{% endschema %}
